<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Sariel's - Ecosistema Digital</title>
    <style>
        body { background-color: #0b0e14; color: #e1e1e1; font-family: sans-serif; padding: 20px; }
        .grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
        .card { background: #181d26; padding: 20px; border-radius: 10px; border: 1px solid #333; }
        .vela-container { height: 200px; display: flex; align-items: flex-end; gap: 5px; }
        .vela { width: 30px; background: #26a69a; height: 100px; }
        .roja { background: #ef5350; height: 60px; }
    </style>
</head>
<body>
    <h1>Sariel's - Ecosistema de Activos</h1>
    <div class="grid">
        <div class="card">
            <h2>Ventas en Tiempo Real</h2>
            <div class="vela-container">
                <div class="vela"></div>
                <div class="vela roja"></div>
                <div class="vela"></div>
            </div>
        </div>
    </div>
</body>
</html>

