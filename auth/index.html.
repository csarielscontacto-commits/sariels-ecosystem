<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Ecosistema de Sariel - Autenticación</title>
    <style>
        body { font-family: sans-serif; background-color: #000; color: #fff; display: flex; justify-content: center; align-items: center; height: 100vh; }
        .login-box { background: #1a1a1a; padding: 40px; border-radius: 15px; text-align: center; border: 1px solid #333; }
        input { padding: 12px; margin: 10px 0; width: 280px; border-radius: 5px; border: 1px solid #333; background: #000; color: #fff; }
        button { padding: 12px 25px; background-color: #fff; color: #000; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; margin-top: 10px; }
    </style>
</head>
<body>

<div class="login-box">
    <h2>Sariel's Ecosystem</h2>
    <input type="email" id="user-email" placeholder="Correo electrónico">
    <input type="password" id="user-password" placeholder="Contraseña">
    <br>
    <button onclick="iniciarSesion()">Entrar al Sistema</button>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
    import { getAuth, signInWithEmailAndPassword } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";

    const firebaseConfig = {
        apiKey: "AIzaSyCZK7dq0SeaMSsqMoSoMdPMfCSSU4MJR-g",
        authDomain: "ecosistema-de-sariel.firebaseapp.com",
        projectId: "ecosistema-de-sariel",
        storageBucket: "ecosistema-de-sariel.firebasestorage.app",
        messagingSenderId: "386188804488",
        appId: "1:386188804488:web:980f3a23bdeb8bf40381cd",
        measurementId: "G-ETJ8T1YTK5"
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    window.iniciarSesion = function() {
        const email = document.getElementById('user-email').value;
        const password = document.getElementById('user-password').value;
        
        signInWithEmailAndPassword(auth, email, password)
            .then((userCredential) => {
                alert("¡Acceso concedido al Ecosistema!");
            })
            .catch((error) => {
                alert("Error: " + error.message);
            });
    };
</script>

</body>
</html>

