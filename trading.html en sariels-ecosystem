                    wickUpColor: '#2ecc71', wickDownColor: '#e74c3c',
                    borderVisible: true
                });
                seriesBandaSuperior = chart.addLineSeries({ color: 'rgba(46, 204, 113, 0.3)', lineWidth: 1, lineStyle: 2, priceLineVisible: false });
                seriesBandaInferior = chart.addLineSeries({ color: 'rgba(231, 76, 60, 0.3)', lineWidth: 1, lineStyle: 2, priceLineVisible: false });
                seriesMedia = chart.addLineSeries({ color: 'rgba(212, 175, 122, 0.4)', lineWidth: 1, lineStyle: 1, priceLineVisible: false });
                chartIndicador = LightweightCharts.createChart(document.getElementById('indicador-container'), {
                    layout: { background: { color: '#0f0c0a' }, textColor: '#8a7a6a' },
                    grid: { vertLines: { color: '#1a1512' }, horzLines: { color: '#1a1512' } },
                    timeScale: { visible: false },
                    rightPriceScale: { visible: false },
                });
                seriesIndicador = chartIndicador.addLineSeries({ color: '#d4af7a', lineWidth: 2, crosshairMarkerVisible: false });
                const seriesSignal = chartIndicador.addLineSeries({ color: '#ff6b6b', lineWidth: 1, lineStyle: 2, crosshairMarkerVisible: false });
                const seriesHist = chartIndicador.addHistogramSeries({ color: '#2ecc71', priceFormat: { type: 'volume' } });
                window.seriesSignal = seriesSignal;
                window.seriesHist = seriesHist;
                chart.timeScale().subscribeVisibleLogicalRangeChange(function(range) {
                    chartIndicador.timeScale().setVisibleLogicalRange(range);
