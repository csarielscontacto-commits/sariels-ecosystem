<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Trading TOK | Sariel's Nexus</title>
<meta name="theme-color" content="#05080f" />
    
<!-- Open Graph -->
<meta property="og:title" content="Sariel's Nexus - Trading TOK" />
<meta property="og:description" content="Plataforma de trading para TOK con gráficos en tiempo real" />
<meta property="og:type" content="website" />

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />

<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Grotesk:wght@300;400;600;700&display=swap" rel="stylesheet" />

<!-- Scripts -->
<script src="https://unpkg.com/@supabase/supabase-js@2"></script>
<script src="https://unpkg.com/lightweight-charts@4.1.3/dist/lightweight-charts.standalone.production.js"></script>
<script src="https://cdn.jsdelivr.net/npm/ethers@5.7.2/dist/ethers.umd.min.js"></script>

<style>
    /* ===== VARIABLES CÓSMICAS ===== */
    :root {
        --space-deep: #05080f;
        --space-mid: #0a1428;
        --space-light: #101f3a;
        --nebula-1: #6c2bd9;
        --nebula-2: #ff6b9d;
        --nebula-3: #00d4ff;
        --gold-cosmic: #f7d44a;
        --gold-dim: rgba(247,212,74,0.15);
        --plasma: #ff3366;
        --quantum: #00e5ff;
        --text-primary: #e8f0f8;
        --text-secondary: #8ba3c7;
        --text-muted: #4a6a8a;
        --border: rgba(0,212,255,0.08);
        --border-glow: rgba(0,212,255,0.25);
        --shadow-neon: 0 0 40px rgba(0,212,255,0.1);
        --shadow-glow: 0 0 60px rgba(108,43,217,0.15);
        --radius: 20px;
        --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        --success: #00b894;
        --warning: #f7d44a;
        --danger: #ff3366;
        --verde: #2ecc71;
        --verde-brillante: #00f5a0;
        --rojo: #e74c3c;
        --rojo-brillante: #ff6b6b;
        --panel: #1a1512;
        --fondo-grafico: #0f0c0a;
        --masa:#0d0b0a;
        --trigo:#d4af7a;
    }

    /* ===== RESET Y BASE ===== */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
        background: var(--space-deep);
        color: var(--text-primary);
        font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
    }

    /* ===== FONDO ESTELAR CON CANVAS ===== */
    #stars-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
    }

    /* ===== NEBULOSAS ===== */
    .nebula {
        position: fixed;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.12;
        pointer-events: none;
        z-index: 0;
        animation: nebula-drift 25s ease-in-out infinite alternate;
    }

    .nebula-1 { width: 700px; height: 700px; background: var(--nebula-1); top: -15%; right: -15%; }
    .nebula-2 { width: 600px; height: 600px; background: var(--nebula-2); bottom: -15%; left: -15%; animation-delay: -8s; }
    .nebula-3 { width: 500px; height: 500px; background: var(--nebula-3); top: 50%; left: 50%; transform: translate(-50%, -50%); animation-delay: -15s; opacity: 0.06; }

    @keyframes nebula-drift {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(40px, -30px) scale(1.15); }
    }

    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--space-deep); }
    ::-webkit-scrollbar-thumb { background: linear-gradient(var(--nebula-3), var(--nebula-1)); border-radius: 3px; }

    /* ===== LAYOUT ===== */
    .app { position: relative; z-index: 1; max-width: 1300px; margin: 0 auto; padding: 20px 24px 40px; }

    /* ===== HEADER ===== */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0 20px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 12px;
        backdrop-filter: blur(10px);
        position: relative;
    }

    .header::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--quantum), var(--nebula-2), var(--quantum), transparent);
        opacity: 0.3;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
    }

    .logo-icon {
        font-size: 2.4rem;
        filter: drop-shadow(0 0 20px rgba(0,212,255,0.3));
        animation: pulse-glow 3s ease-in-out infinite;
    }

    @keyframes pulse-glow {
        0%, 100% { filter: drop-shadow(0 0 20px rgba(0,212,255,0.3)); }
        50% { filter: drop-shadow(0 0 40px rgba(247,212,74,0.4)); }
    }

    .logo-text {
        font-family: 'Orbitron', monospace;
        font-size: 1.6rem;
        font-weight: 900;
        letter-spacing: 2px;
        background: linear-gradient(135deg, var(--text-primary), var(--quantum), var(--nebula-2));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 0 40px rgba(0,212,255,0.2);
    }

    .logo-badge {
        font-family: 'Orbitron', monospace;
        font-size: 0.5rem;
        background: linear-gradient(135deg, var(--nebula-1), var(--nebula-2));
        color: white;
        padding: 4px 14px;
        border-radius: 20px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        -webkit-text-fill-color: white;
        box-shadow: 0 0 30px rgba(108,43,217,0.3);
        animation: badge-pulse 2s ease-in-out infinite;
    }

    @keyframes badge-pulse {
        0%, 100% { box-shadow: 0 0 30px rgba(108,43,217,0.3); }
        50% { box-shadow: 0 0 60px rgba(255,107,157,0.4); }
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .status-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(0,212,255,0.06);
        border: 1px solid rgba(0,212,255,0.15);
        padding: 8px 18px;
        border-radius: 30px;
        font-size: 0.65rem;
        color: var(--quantum);
        font-family: 'Orbitron', monospace;
        letter-spacing: 1px;
        backdrop-filter: blur(10px);
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: quantum-pulse 1.5s ease-in-out infinite;
    }

    .status-dot.online { background: var(--success); box-shadow: 0 0 20px rgba(0,184,148,0.5); }
    .status-dot.offline { background: var(--text-muted); box-shadow: 0 0 20px rgba(74,106,138,0.3); }

    @keyframes quantum-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.7); }
    }

    /* ===== BOTONES ===== */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border: 1px solid var(--border);
        border-radius: 30px;
        background: rgba(0,212,255,0.03);
        color: var(--text-primary);
        font-family: 'Orbitron', monospace;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: var(--transition);
        text-decoration: none;
    }

    .btn:hover { transform: scale(1.03); border-color: var(--border-glow); }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none !important; }

    .btn-primary {
        background: linear-gradient(135deg, var(--nebula-1), var(--nebula-2));
        border-color: transparent;
        color: white;
        -webkit-text-fill-color: white;
    }

    .btn-primary:hover:not(:disabled) {
        background: linear-gradient(135deg, var(--nebula-2), var(--nebula-1));
        box-shadow: 0 0 40px rgba(108,43,217,0.3);
    }

    .btn-success {
        background: linear-gradient(135deg, #00b894, #00897b);
        border-color: transparent;
        color: white;
        -webkit-text-fill-color: white;
    }

    .btn-success:hover:not(:disabled) {
        background: linear-gradient(135deg, #00897b, #00695c);
        box-shadow: 0 0 40px rgba(0,184,148,0.3);
    }

    .btn-danger {
        background: rgba(255,51,102,0.15);
        border-color: rgba(255,51,102,0.3);
        color: var(--danger);
    }

    .btn-danger:hover:not(:disabled) { background: rgba(255,51,102,0.25); }

    .btn-gold {
        background: linear-gradient(135deg, var(--gold-cosmic), #b8923a);
        border-color: transparent;
        color: #0a0c10;
        -webkit-text-fill-color: #0a0c10;
    }

    .btn-gold:hover:not(:disabled) { box-shadow: 0 0 40px rgba(247,212,74,0.3); }

    .btn-outline {
        border-color: var(--border);
        background: transparent;
    }

    .btn-outline:hover:not(:disabled) {
        background: rgba(0,212,255,0.05);
        border-color: var(--quantum);
    }

    .btn-sm { padding: 6px 14px; font-size: 0.6rem; }
    .btn-block { width: 100%; justify-content: center; }

    .btn-volver {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: rgba(212,175,122,0.1);
        border: 1px solid rgba(212,175,122,0.2);
        border-radius: 8px;
        color: var(--trigo);
        font-size: 0.7rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        margin-bottom: 12px;
    }

    .btn-volver:hover {
        background: rgba(212,175,122,0.2);
        transform: translateY(-1px);
    }

    /* ===== ESTADO CONEXIÓN ===== */
    .estado-conexion {
        font-size: 0.65rem;
        color: #6a5d50;
        padding: 5px 16px;
        background: #11100e;
        border-bottom: 1px solid #1f1a16;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 12px;
    }

    .estado-conexion .dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #6a5d50;
        display: inline-block;
    }

    .estado-conexion.conectado .dot { background: var(--verde-brillante); box-shadow: 0 0 8px rgba(0,245,160,0.3); }
    .estado-conexion.conectado { color: var(--verde-brillante); }

    /* ===== GRÁFICO ===== */
    #chart-container { width: 100%; height: 340px; background: var(--fondo-grafico); position: relative; }
    #indicador-container { width: 100%; height: 100px; border-top: 1px solid #1f1a16; background: var(--fondo-grafico); }

    /* ===== INDICADORES INFO ===== */
    .indicadores-info {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 16px;
        padding: 6px 16px;
        background: #0d0b0a;
        border-bottom: 1px solid #1f1a16;
        font-size: 0.6rem;
        color: #6a5d50;
        font-family: 'Inter', monospace;
        letter-spacing: 0.2px;
    }

    .indicadores-info .bb, .indicadores-info .vol, .indicadores-info .macd {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .indicadores-info .valor { color: #b8a898; font-weight: 500; }
    .indicadores-info .valor.verde { color: var(--verde-brillante); }
    .indicadores-info .valor.rojo { color: var(--rojo-brillante); }
    .indicadores-info .valor.trigo { color: var(--gold-cosmic); }

    /* ===== TIMEFRAMES ===== */
    .timeframes {
        display: flex;
        gap: 4px;
        padding: 8px 16px;
        background: var(--fondo-grafico);
        border-bottom: 1px solid #1f1a16;
    }

    .timeframes button {
        background: transparent;
        border: none;
        color: #6a5d50;
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        letter-spacing: 0.3px;
        font-family: 'Orbitron', monospace;
    }

    .timeframes button:hover { color: var(--text-primary); }
    .timeframes button.activo {
        color: #fff;
        background: rgba(212,175,122,0.15);
    }

    .slogan-wrapper {
        padding: 6px 16px;
        background: #11100e;
        border-bottom: 1px solid #1f1a16;
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 12px;
    }

    .slogan-icono { flex-shrink: 0; width: 20px; height: 20px; margin-top: 1px; }
    .slogan-texto {
        font-size: 0.65rem;
        line-height: 1.5;
        color: #8a7a6a;
        font-style: italic;
    }
    .slogan-texto strong { color: var(--gold-cosmic); font-style: normal; }

    .aceptacion-check-wrapper {
        padding: 6px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        background: #11100e;
        border-bottom: 1px solid #1f1a16;
    }

    .aceptacion-check-wrapper input[type="checkbox"] {
        width: 15px;
        height: 15px;
        accent-color: #d4af7a;
        cursor: pointer;
        flex-shrink: 0;
        appearance: none;
        -webkit-appearance: none;
        background: #1a1512;
        border: 2px solid #3a2f26;
        border-radius: 3px;
        transition: all 0.2s;
        position: relative;
    }

    .aceptacion-check-wrapper input[type="checkbox"]:checked {
        background: #d4af7a;
        border-color: #d4af7a;
    }

    .aceptacion-check-wrapper input[type="checkbox"]:checked::after {
        content: "✓";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: var(--masa);
        font-size: 10px;
        font-weight: 700;
    }

    .aceptacion-check-wrapper label {
        font-size: 0.65rem;
        color: #8a7a6a;
        cursor: pointer;
    }

    .aceptacion-check-wrapper label strong {
        color: var(--trigo);
        text-decoration: underline;
        cursor: pointer;
    }

    .conexion-check-wrapper {
        padding: 6px 16px;
        display: none;
        align-items: center;
        gap: 10px;
        background: #11100e;
        border-bottom: 1px solid #1f1a16;
    }

    .conexion-check-wrapper.visible { display: flex; }

    .conexion-check-wrapper input[type="checkbox"] {
        width: 15px;
        height: 15px;
        accent-color: #f6851b;
        cursor: pointer;
        flex-shrink: 0;
        appearance: none;
        -webkit-appearance: none;
        background: #1a1512;
        border: 2px solid #3a2f26;
        border-radius: 3px;
        transition: all 0.2s;
        position: relative;
    }

    .conexion-check-wrapper input[type="checkbox"]:checked {
        background: #f6851b;
        border-color: #f6851b;
    }

    .conexion-check-wrapper input[type="checkbox"]:checked::after {
        content: "✓";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
    }

    .conexion-check-wrapper label {
        font-size: 0.7rem;
        color: #8a7a6a;
        cursor: pointer;
    }

    .conexion-check-wrapper label strong { color: var(--trigo); }

    .panel-wallet {
        padding: 14px 16px;
        background: rgba(10,20,40,0.6);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        margin: 12px 0;
        backdrop-filter: blur(10px);
        position: relative;
        overflow: hidden;
    }

    .panel-wallet::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        background: linear-gradient(135deg, var(--quantum), var(--nebula-1), var(--nebula-2), var(--quantum));
        background-size: 300% 300%;
        border-radius: var(--radius);
        z-index: -1;
        opacity: 0;
        animation: border-flow 4s ease-in-out infinite;
    }

    .panel-wallet:hover::before { opacity: 0.3; }

    @keyframes border-flow {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    .panel-wallet .btn-wallet {
        width: 100%;
        padding: 10px;
        background: linear-gradient(135deg, #f6851b, #e07a15);
        border: none;
        border-radius: 8px;
        color: #fff;
        font-weight: 600;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .panel-wallet .btn-wallet:hover { transform: scale(1.01); box-shadow: 0 4px 20px rgba(246,133,27,0.2); }

    .panel-wallet .wallet-direccion {
        font-size: 0.7rem;
        color: var(--gold-cosmic);
        word-break: break-all;
        margin-top: 4px;
        font-family: monospace;
    }

    .saldos-grid {
        display: flex;
        gap: 6px;
        margin-top: 6px;
    }

    .saldo-item {
        flex: 1;
        background: rgba(0,0,0,0.2);
        border-radius: 6px;
        padding: 6px 8px;
        text-align: center;
        border: 1px solid var(--border);
    }

    .saldo-item .label { font-size: 0.55rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
    .saldo-item .valor { font-size: 0.8rem; font-weight: 600; color: var(--text-primary); }

    .panel-operar {
        padding: 14px 16px;
        background: rgba(10,20,40,0.6);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        margin: 12px 0;
        backdrop-filter: blur(10px);
        position: relative;
        overflow: hidden;
    }

    .panel-operar::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        background: linear-gradient(135deg, var(--quantum), var(--nebula-1), var(--nebula-2), var(--quantum));
        background-size: 300% 300%;
        border-radius: var(--radius);
        z-index: -1;
        opacity: 0;
        animation: border-flow 4s ease-in-out infinite;
    }

    .panel-operar:hover::before { opacity: 0.3; }

    .tabs-operar {
        display: flex;
        gap: 0;
        margin-bottom: 10px;
        border-radius: 8px;
        overflow: hidden;
        background: rgba(0,0,0,0.2);
    }

    .tab-btn {
        flex: 1;
        padding: 8px;
        text-align: center;
        background: transparent;
        border: none;
        color: var(--text-muted);
        font-size: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        font-family: 'Orbitron', monospace;
    }

    .tab-btn.comprar.activo { background: var(--verde); color: #fff; }
    .tab-btn.vender.activo { background: var(--rojo); color: #fff; }
    .tab-btn:hover:not(.activo) { color: var(--text-primary); }

    .campo { margin-bottom: 8px; }
    .campo label { display: block; font-size: 0.65rem; color: var(--text-muted); margin-bottom: 2px; letter-spacing: 0.3px; font-family: 'Orbitron', monospace; }

    .campo input {
        width: 100%;
        padding: 8px 12px;
        background: rgba(0,0,0,0.2);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 0.85rem;
        outline: none;
        transition: border 0.2s;
        font-family: 'Space Grotesk', sans-serif;
    }

    .campo input:focus { border-color: var(--gold-cosmic); }
    .campo input:disabled { opacity: 0.6; }

    .gas-estimado {
        font-size: 0.65rem;
        color: var(--text-muted);
        margin: -2px 0 8px;
        padding: 5px 8px;
        background: rgba(0,0,0,0.15);
        border-radius: 6px;
        display: flex;
        justify-content: space-between;
    }

    .gas-estimado span:last-child { color: var(--gold-cosmic); font-weight: 500; }

    .btn-ejecutar {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        color: #fff;
        cursor: pointer;
        transition: all 0.2s;
        font-family: 'Orbitron', monospace;
    }

    .btn-ejecutar.comprar { background: linear-gradient(135deg, var(--verde), #1a9c5a); }
    .btn-ejecutar.vender { background: linear-gradient(135deg, var(--rojo), #c0392b); }
    .btn-ejecutar:hover { transform: scale(1.01); }
    .btn-ejecutar:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .panel-portafolio {
        padding: 14px 16px;
        background: rgba(10,20,40,0.6);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        margin: 12px 0;
        backdrop-filter: blur(10px);
        position: relative;
        overflow: hidden;
    }

    .panel-portafolio::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        background: linear-gradient(135deg, var(--quantum), var(--nebula-1), var(--nebula-2), var(--quantum));
        background-size: 300% 300%;
        border-radius: var(--radius);
        z-index: -1;
        opacity: 0;
        animation: border-flow 4s ease-in-out infinite;
    }

    .panel-portafolio:hover::before { opacity: 0.3; }

    .tabs-portafolio { display: flex; background: rgba(0,0,0,0.15); border-radius: 8px; overflow: hidden; margin-bottom: 10px; }
