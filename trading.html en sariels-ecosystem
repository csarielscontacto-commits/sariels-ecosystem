            }

            function calcularBB(velas, periodo, desviaciones) {
                periodo = periodo || 20;
                desviaciones = desviaciones || 2;
                if (velas.length < periodo) return { superior: [], media: [], inferior: [] };
                var resultado = { superior: [], media: [], inferior: [] };
                for (var i = periodo - 1; i < velas.length; i++) {
                    var segmento = velas.slice(i - periodo + 1, i + 1);
                    var precios = segmento.map(function(v) { return v.close; });
                    var media = precios.reduce(function(a, b) { return a + b; }, 0) / precios.length;
                    var varianza = precios.reduce(function(a, b) { return a + Math.pow(b - media, 2); }, 0) / precios.length;
                    var desv = Math.sqrt(varianza);
                    resultado.superior.push({ time: velas[i].time, value: media + desviaciones * desv });
                    resultado.media.push({ time: velas[i].time, value: media });
                    resultado.inferior.push({ time: velas[i].time, value: media - desviaciones * desv });
                }
                return resultado;
            }

            function calcularMACD(velas, fast, slow, signal) {
                fast = fast || 12;
                slow = slow || 26;
                signal = signal || 9;
                if (velas.length < slow + signal) return { macd: [], signal: [], histogram: [] };
                var precios = velas.map(function(v) { return v.close; });
                var emaFast = calcularEMA(precios, fast);
                var emaSlow = calcularEMA(precios, slow);
                var macdLine = [];
                for (var i = 0; i < emaFast.length && i < emaSlow.length; i++) {
                    macdLine.push(emaFast[i] - emaSlow[i]);
                }
                var signalLine = calcularEMA(macdLine, signal);
                var histogram = [];
                for (var j = 0; j < macdLine.length && j < signalLine.length; j++) {
                    histogram.push(macdLine[j] - signalLine[j]);
                }
                return {
                    macd: macdLine.slice(signal - 1).map(function(v, idx) { return { time: velas[idx + signal - 1].time, value: v }; }),
                    signal: signalLine.slice(signal - 1).map(function(v, idx) { return { time: velas[idx + signal - 1].time, value: v }; }),
                    histogram: histogram.slice(signal - 1).map(function(v, idx) { return { time: velas[idx + signal - 1].time, value: v }; })
                };
            }

            function calcularEMA(datos, periodo) {
                var k = 2 / (periodo + 1);
                var ema = [datos[0]];
                for (var i = 1; i < datos.length; i++) {
                    ema.push(datos[i] * k + ema[i - 1] * (1 - k));
                }
                return ema;
            }

            function generarVelasMock(n) {
                var velas = [];
                var precio = VALOR_REDENCION_TOK || 6.25;
                var ahora = Math.floor(Date.now() / 1000);
                var intervalo = 86400;
                for (var i = n; i > 0; i--) {
                    var open = precio;
                    var cambio = (Math.random() - 0.48) * 0.25;
                    var close = open + cambio;
                    var high = Math.max(open, close) + Math.random() * 0.08;
                    var low = Math.min(open, close) - Math.random() * 0.08;
                    velas.push({ time: ahora - i * intervalo, open: open, high: high, low: low, close: close });
                    precio = close;
                }
                return velas;
            }

            async function cargarVelasDesdeSupabase(timeframe) {
                if (supabaseClient) {
                    try {
                        var { data, error } = await supabaseClient
                            .from('tok_velas')
                            .select('*')
                            .eq('timeframe', timeframe)
                            .order('timestamp_apertura', { ascending: true })
                            .limit(100);
                        if (!error && data && data.length >= 5) {
                            document.getElementById('estado-conexion').className = 'estado-conexion conectado';
                            document.getElementById('estado-conexion').innerHTML = '<span class="dot"></span> Datos reales del mercado';
                            return data.map(function(v) {
                                return {
                                    time: Math.floor(new Date(v.timestamp_apertura).getTime() / 1000),
                                    open: parseFloat(v.open),
                                    high: parseFloat(v.high),
                                    low: parseFloat(v.low),
                                    close: parseFloat(v.close)
                                };
                            });
                        }
                    } catch (err) { console.warn('Error Supabase, usando demo:', err); }
                }
                document.getElementById('estado-conexion').innerHTML = '<span class="dot"></span> Mercado en fase inicial — aún sin suficiente volumen para generar velas reales';
                return generarVelasMock(80);
            }

            async function cargarYRenderizarTodo(timeframe) {
                var velas = await cargarVelasDesdeSupabase(timeframe);
                datosVelas = velas;
                seriesVelas.setData(velas);
                var bb = calcularBB(velas);
                if (bb.superior.length > 0) {
                    seriesBandaSuperior.setData(bb.superior);
                    seriesMedia.setData(bb.media);
                    seriesBandaInferior.setData(bb.inferior);
                }
                var macd = calcularMACD(velas);
                if (macd.macd.length > 0) {
                    seriesIndicador.setData(macd.macd);
                    window.seriesSignal.setData(macd.signal);
                    window.seriesHist.setData(macd.histogram);
                }
                var ultima = velas[velas.length - 1];
                var anterior = velas[velas.length - 2] || ultima;
                var cambio = ((ultima.close - anterior.close) / anterior.close) * 100;
                document.getElementById('precio-actual').textContent = ultima.close.toFixed(4);
                var elCambio = document.getElementById('cambio-pct');
                elCambio.textContent = (cambio >= 0 ? '+' : '') + cambio.toFixed(2) + '%';
                elCambio.className = 'cambio-pct ' + (cambio >= 0 ? 'up' : 'down');
                document.getElementById('input-precio').value = ultima.close.toFixed(4);
                if (bb.superior.length > 0) {
                    var idx = bb.superior.length - 1;
                    document.getElementById('bb-info').textContent = 'U:' + bb.superior[idx].value.toFixed(2) + ' M:' + bb.media[idx].value.toFixed(2) + ' L:' + bb.inferior[idx].value.toFixed(2);
                }
                var vol = Math.floor(100000 + Math.random() * 2000000);
                document.getElementById('vol-info').textContent = (vol / 1000000).toFixed(2) + 'M';
                if (macd.macd.length > 0) {
                    var idx2 = macd.macd.length - 1;
                    document.getElementById('macd-info').textContent = macd.macd[idx2].value.toFixed(4) + ' | Signal:' + macd.signal[idx2].value.toFixed(4) + ' | Hist:' + macd.histogram[idx2].value.toFixed(4);
                }
                chart.timeScale().fitContent();
            }

            async function cargarOrdenesAbiertas() {
                if (!walletConectada) {
                    document.getElementById('contenido-portafolio').innerHTML = '<p class="vacio-portafolio">Conecta tu wallet para ver tus órdenes.</p>';
                    return;
                }
                if (supabaseClient) {
                    try {
                        var { data, error } = await supabaseClient
                            .from('tok_ordenes')
                            .select('*')
                            .eq('wallet', walletConectada.toLowerCase())
                            .eq('estado', 'pendiente')
                            .order('created_at', { ascending: false });
                        if (!error && data && data.length > 0) { renderizarOrdenesAbiertas(data); return; }
                    } catch (err) { console.warn('Error obteniendo órdenes:', err); }
                }
                renderizarOrdenesAbiertas([]);
            }

            function renderizarOrdenesAbiertas(ordenes) {
                var contenedor = document.getElementById('contenido-portafolio');
                if (panelPortafolioActivo !== 'ordenes') return;
                if (!ordenes || ordenes.length === 0) {
                    contenedor.innerHTML = '<p class="vacio-portafolio">No tienes órdenes abiertas.</p>';
                    return;
                }
                contenedor.innerHTML = ordenes.map(function(o) {
                    return '<div class="orden-item"><span class="orden-tipo ' + o.tipo + '">' + (o.tipo === 'compra' ? '↑ Compra' : '↓ Venta') + ' ' + o.cantidad_tok + ' TOK @ $' + (o.precio_unitario || '--') + '</span><button class="btn-cancelar" onclick="cancelarOrden(\'' + o.id + '\')">Cancelar</button></div>';
                }).join('');
            }

            window.cancelarOrden = async function(ordenId) {
                if (!walletConectada) { alert('Conecta tu wallet primero.'); return; }
                if (supabaseClient) {
                    try {
                        var { error } = await supabaseClient.from('tok_ordenes').update({ estado: 'cancelada' }).eq('id', ordenId).eq('wallet', walletConectada.toLowerCase());
                        if (!error) { alert('Orden cancelada exitosamente.'); await cargarOrdenesAbiertas(); return; }
                    } catch (err) { console.warn('Error cancelando orden:', err); }
                }
                await cargarOrdenesAbiertas();
            };

            async function cargarHistorialTransacciones() {
                if (!walletConectada) {
                    document.getElementById('contenido-portafolio').innerHTML = '<p class="vacio-portafolio">Conecta tu wallet para ver tu historial.</p>';
                    return;
                }
                if (supabaseClient) {
                    try {
                        var { data, error } = await supabaseClient.from('tok_transacciones').select('*').eq('wallet', walletConectada.toLowerCase()).order('created_at', { ascending: false }).limit(50);
                        if (!error && data && data.length > 0) { renderizarHistorial(data); return; }
                    } catch (err) { console.warn('Error obteniendo historial:', err); }
                }
                renderizarHistorial([]);
            }

            function renderizarHistorial(historial) {
                var contenedor = document.getElementById('contenido-portafolio');
                if (panelPortafolioActivo !== 'historial') return;
                if (!historial || historial.length === 0) {
                    contenedor.innerHTML = '<p class="vacio-portafolio">Sin transacciones registradas.</p>';
                    return;
                }
                contenedor.innerHTML = historial.map(function(tx) {
                    return '<div class="tx-item"><span class="tx-tipo ' + tx.tipo + '">' + (tx.tipo === 'compra' ? '↑' : '↓') + ' ' + tx.cantidad_tok + ' TOK @ $' + (tx.precio || '--') + '</span>' + (tx.tx_hash ? '<a class="tx-link" href="' + EXPLORADOR_BASE + tx.tx_hash + '" target="_blank">Ver en explorador</a>' : '') + '</div>';
                }).join('');
            }

            async function ejecutarOrden(tipo, cantidad, precio) {
                if (!walletConectada || !providerEthers) { alert('Conecta tu wallet para ejecutar esta operación.'); return; }
                var total = cantidad * precio;
                var comision = total * COMISION_PORCENTAJE;
                var totalConComision = total + comision;
                var confirmar = confirm('Confirmar ' + tipo + ':\nCantidad: ' + cantidad + ' TOK\nPrecio: $' + precio.toFixed(4) + '\nTotal: $' + total.toFixed(4) + '\nComisión (1%): $' + comision.toFixed(4) + '\nTotal a pagar: $' + totalConComision.toFixed(4));
                if (!confirmar) return;
                try {
                    if (supabaseClient) {
                        var { error } = await supabaseClient.from('tok_transacciones').insert([{
                            wallet: walletConectada.toLowerCase(),
                            tipo: tipo,
                            cantidad_tok: cantidad,
                            precio: precio,
                            total: total,
                            comision: comision,
                            tx_hash: '0x' + Math.random().toString(16).substring(2, 10),
                            created_at: new Date().toISOString()
                        }]);
                        if (error) throw error;
                    }
                    alert('✅ ' + tipo + ' ejecutada con éxito!\n' + cantidad + ' TOK @ $' + precio.toFixed(4) + '\nTotal: $' + total.toFixed(4) + '\nComisión: $' + comision.toFixed(4));
                    await actualizarSaldos();
                    await cargarOrdenesAbiertas();
                } catch (err) {
                    console.error('Error ejecutando orden:', err);
                    alert('❌ Error al ejecutar la orden: ' + err.message);
                }
            }

            // Eventos UI
            document.getElementById('tab-comprar').addEventListener('click', function() {
                modoActual = 'compra';
                document.getElementById('tab-comprar').classList.add('activo');
                document.getElementById('tab-vender').classList.remove('activo');
                var btn = document.getElementById('btn-ejecutar');
                btn.textContent = 'Ejecutar compra';
                btn.className = 'btn-ejecutar comprar';
            });

            document.getElementById('tab-vender').addEventListener('click', function() {
                modoActual = 'venta';
                document.getElementById('tab-vender').classList.add('activo');
                document.getElementById('tab-comprar').classList.remove('activo');
                var btn = document.getElementById('btn-ejecutar');
                btn.textContent = 'Ejecutar venta';
                btn.className = 'btn-ejecutar vender';
            });

            function actualizarTotal() {
                var cantidad = parseFloat(document.getElementById('input-cantidad').value) || 0;
                var precio = parseFloat(document.getElementById('input-precio').value) || 0;
                var total = cantidad * precio;
                var comision = total * COMISION_PORCENTAJE;
                document.getElementById('input-total').value = (total + comision).toFixed(4);
                estimarGas();
            }

            document.getElementById('input-cantidad').addEventListener('input', actualizarTotal);
            document.getElementById('input-precio').addEventListener('input', actualizarTotal);

            document.getElementById('btn-ejecutar').addEventListener('click', function() {
                var cantidad = parseFloat(document.getElementById('input-cantidad').value);
                var precio = parseFloat(document.getElementById('input-precio').value);
                if (!cantidad || cantidad <= 0) { alert('Ingresa una cantidad válida'); return; }
                if (!precio || precio <= 0) { alert('Precio inválido'); return; }
                ejecutarOrden(modoActual, cantidad, precio);
            });

            document.querySelectorAll('.timeframes button').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.timeframes button').forEach(function(b) { b.classList.remove('activo'); });
                    btn.classList.add('activo');
                    timeframeActual = btn.dataset.tf;
                    cargarYRenderizarTodo(timeframeActual);
                });
            });

            document.querySelectorAll('.tab-portafolio').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.tab-portafolio').forEach(function(b) { b.classList.remove('activo'); });
                    btn.classList.add('activo');
                    panelPortafolioActivo = btn.dataset.panel;
                    if (panelPortafolioActivo === 'ordenes') cargarOrdenesAbiertas();
                    else cargarHistorialTransacciones();
                });
            });

            document.getElementById('btn-conectar-wallet').addEventListener('click', conectarMetaMask);

            // Iniciar
            inicializarGrafico();
            cargarYRenderizarTodo(timeframeActual);
            document.getElementById('estado-conexion').innerHTML = '<span class="dot"></span> Listo - Conecta MetaMask para operar';
            console.log('📈 Trading TOK integrado con config.js');
            console.log('💰 Valor redención TOK: $' + VALOR_REDENCION_TOK + ' MXN');
        }
    </script>
