                    timeScale: { borderColor: '#1f1a16' },
                    rightPriceScale: { borderColor: '#1f1a16' },
                });
                seriesVelas = chart.addCandlestickSeries({
                    upColor: '#2ecc71', downColor: '#e74c3c',
