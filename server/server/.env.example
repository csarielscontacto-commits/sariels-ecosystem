PORT=8787
NODE_ENV=development

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# JWT secret para verificar access token de Supabase (Settings > API > JWT secret)
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# Proveedor activo: nowpayments | coinbase
PAYMENT_PROVIDER=nowpayments

# NOWPayments
NOWPAYMENTS_API_KEY=YOUR_NOWPAYMENTS_API_KEY
NOWPAYMENTS_IPN_SECRET=YOUR_NOWPAYMENTS_IPN_SECRET

# Coinbase (si luego activas coinbase)
COINBASE_COMMERCE_API_KEY=YOUR_COINBASE_COMMERCE_API_KEY
COINBASE_WEBHOOK_SECRET=YOUR_COINBASE_WEBHOOK_SECRET

# Política: red permitida por moneda (producción estricta)
USDT_ALLOWED_NETWORK=TRC20
USDC_ALLOWED_NETWORK=ERC20
